    "@google/generative-ai": "^0.24.1",
    "@types/multer": "^2.1.0",
    "@types/sax": "^1.2.7",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dicom-parser": "^1.8.21",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.0",

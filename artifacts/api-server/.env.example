# Plexara API server — environment template.
# Copy values you need into a real .env (never commit secrets).

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/plexara

# ── Sessions / PHI encryption ───────────────────────────────────────────
SESSION_SECRET=replace_with_long_random_string
PHI_MASTER_KEY=replace_with_64_hex_chars_or_base64_32_bytes

# ── LLM model selection ────────────────────────────────────────────────
# Per-lens overrides — see lib/llm-client.ts for defaults.
# LLM_LENS_A_MODEL=claude-sonnet-4-6
# LLM_LENS_B_MODEL=gpt-5.2
# LLM_LENS_C_MODEL=gemini-2.5-flash
# LLM_RECONCILIATION_MODEL=claude-sonnet-4-6
# LLM_UTILITY_MODEL=claude-sonnet-4-6

# Extraction model — a faster, cheaper Haiku-class model is sufficient
# for structured data extraction from PDFs/images. Saves ~3-5s per
# upload. (Enhancement A1)
LLM_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Chat & Journal model — conversational Q&A, doesn't need Sonnet reasoning.
# Default: claude-haiku-4-5-20251001 (3-5x faster than Sonnet)
LLM_CHAT_MODEL=claude-haiku-4-5-20251001

# ── Object storage ──────────────────────────────────────────────────────
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ── Sentry error monitoring ─────────────────────────────────────────────
# Set SENTRY_DSN to enable error reporting. Leave blank to disable Sentry.
SENTRY_DSN=
# Git SHA or semver tag included in every Sentry event for release tracking.
# Falls back to `git rev-parse HEAD` at boot if unset.
RELEASE_VERSION=
# Salt used when hashing patient identifiers before sending to Sentry.
# REQUIRED in production — boot will refuse to start without it when SENTRY_DSN is set.
SENTRY_USER_SALT=
# Set to "true" to enable the /__sentry-test smoke-test endpoint.
SENTRY_TEST_ENABLED=
# Secret token required in the X-Sentry-Test-Token header to reach /__sentry-test.
SENTRY_TEST_TOKEN=

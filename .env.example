# ============================================
# PLEXARA ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in real values.
# In Replit, secrets are managed in the Secrets pane (not via .env).
# This file is the migration developer's setup contract for any host
# (GCP Cloud Run, AWS ECS, fly.io, bare Docker, etc).

# ---------- Application ----------
NODE_ENV=development
# API server port. Must be set; api-server throws on missing PORT.
PORT=8080
# Public URL the frontend uses to call the API. In dev this is the
# Replit dev domain; in prod it's plexara.health (or whatever the deploy uses).
APP_URL=http://localhost:8080
APP_VERSION=0.1.0
LOG_LEVEL=info

# ---------- Database ----------
# Standard PostgreSQL connection string. Works with Neon, Cloud SQL, RDS,
# Supabase, fly Postgres, or self-hosted. The pg Pool in lib/db/src/index.ts
# parses this directly.
DATABASE_URL=postgresql://user:password@host:5432/plexara

# ---------- Authentication (Clerk) ----------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
# Comma-separated Clerk user IDs that have admin powers (compliance/admin routes).
PLEXARA_ADMIN_USER_IDS=

# ---------- Sessions / Crypto ----------
# 32+ random bytes, base64 or hex. Used by cookie-parser and lib/crypto.ts.
# Generate locally: `openssl rand -base64 48`
SESSION_SECRET=

# ---------- File Storage ----------
# Provider for persistent uploaded files (records, DICOM, genetics).
#   local         → on-disk under FILE_STORAGE_PATH (dev / single-node)
#   replit-objects → Replit-hosted GCS sidecar (current production-on-Replit)
#   s3            → AWS S3 (future; migration developer implements adapter)
#   gcs           → Google Cloud Storage direct (future)
STORAGE_PROVIDER=local
FILE_STORAGE_PATH=./uploads

# Replit Object Storage (only used when STORAGE_PROVIDER=replit-objects).
# Set automatically by Replit when an Object Storage bucket is provisioned.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# HMAC key for signing local-storage URLs (only used when STORAGE_PROVIDER=local).
# Falls back to SESSION_SECRET if unset, but in production set this to a
# dedicated 32+ byte random value so rotating session secrets doesn't
# invalidate every signed file URL in flight.
STORAGE_LOCAL_SIGNING_SECRET=

# Future cloud storage (commented out until migration):
# S3_BUCKET_NAME=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GCS_BUCKET_NAME=
# GCS_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=

# ---------- LLM Configuration ----------
# Each lens picks a provider + model independently. The pipeline reads
# these at runtime so you can re-route lenses without code changes.
# Providers: anthropic | openai | google
LLM_LENS_A_PROVIDER=anthropic
LLM_LENS_A_MODEL=claude-sonnet-4-6
LLM_LENS_B_PROVIDER=openai
LLM_LENS_B_MODEL=gpt-5.2
LLM_LENS_C_PROVIDER=google
LLM_LENS_C_MODEL=gemini-2.5-flash
LLM_RECONCILIATION_PROVIDER=anthropic
LLM_RECONCILIATION_MODEL=claude-sonnet-4-6
# Utility model — used for OCR, vision, doc summarisation, and the chat
# assistant. Falls back to LLM_RECONCILIATION_MODEL if unset.
LLM_UTILITY_MODEL=
# Chat assistant model. Falls back to LLM_RECONCILIATION_MODEL if unset.
LLM_CHAT_MODEL=

# Provider credentials. The AI_INTEGRATIONS_* vars route through Replit's
# AI proxy in dev. To migrate to direct provider APIs, leave BASE_URL empty
# and set the API key to your real key from the provider dashboard.
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# ---------- Feature Flags ----------
ENABLE_ACTIVE_ALERTS=true
ENABLE_PREDICTIVE_TRAJECTORIES=false
ENABLE_PHYSICIAN_PORTAL=false
ENABLE_DICOM_VIEWER=true

# ---------- Security / CORS ----------
# Comma-separated list of allowed origins for the API. In prod this should
# be the exact frontend origin(s) — never `*` for an authenticated app.
# In dev, leave empty to reflect the request origin (compatible with
# Replit's variable preview hosts).
CORS_ORIGIN=

# Rate limiting (express-rate-limit).
# Window in ms and request cap per IP per window for the global /api limiter.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=600
# Stricter limits for LLM-expensive endpoints (chat, records, interpretations,
# predictions, reports, protocols, genetics, correlations, supplements, imaging).
RATE_LIMIT_LLM_MAX_REQUESTS=30
# Stricter limits still for sensitive-action endpoints — share-link issuance,
# physician invitations, compliance exports, and dev-auth bypass. Real users
# hit these single-digits per hour; raise only if you have a measured need.
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=20

# ---------- Single-container deploy (optional) ----------
# Set STATIC_DIR to the absolute path of the built frontend (artifacts/plexara/dist/public)
# to have the API server serve the SPA itself. Leave unset for split deploys
# where a CDN serves the frontend.
STATIC_DIR=

# ---------- Frontend (Vite — must be prefixed VITE_) ----------
# Optional: route Clerk frontend traffic through a same-origin proxy to
# avoid third-party-cookie issues in Safari/Brave. Leave unset to talk
# to Clerk directly.
VITE_CLERK_PROXY_URL=
